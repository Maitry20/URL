# ==============================================================================
# SnipLink URL Shortener - Local Environment Configuration Template
# ==============================================================================
# Rename this file to '.env' and fill in your actual connection credentials.
# Do NOT commit your active '.env' file to source control!

# --- App Settings ---
DEBUG=True

# --- MySQL Database Config ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=url_shortener

# --- Redis Cache Config ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- AWS DynamoDB Config (User profiles) ---
# Set these variables if using actual AWS DynamoDB or LocalStack.
# If running inside an AWS environment with IAM roles, you can leave the credentials blank.
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
DYNAMODB_TABLE=users

# Optional: Set this to redirect DynamoDB requests to a local DynamoDB / LocalStack instance.
# Example: http://localhost:8000 (if running DynamoDB Local on 8000)
DYNAMODB_ENDPOINT_URL=

# --- JWT Auth Config ---
# Generate a secure secret key in production (e.g. using 'openssl rand -hex 32')
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production_12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
